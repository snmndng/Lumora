{
  "version": 2,
  "builds": [
    {
      "src": "saleor/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/saleor/wsgi.py"
    }
  ],
  "env": {
    "FILE_UPLOAD_MAX_MEMORY_SIZE": "5242880",
    "DATA_UPLOAD_MAX_MEMORY_SIZE": "5242880",
    "SOFT_MEMORY_LIMIT_IN_MB": "400",
    "HARD_MEMORY_LIMIT_IN_MB": "450"
  },
  "functions": {
    "saleor/wsgi.py": {
      "maxDuration": 30
    }
  }
}